# API Configuration
VITE_API_BASE_URL=https://api.cukaipro.com/v1
VITE_API_TIMEOUT=30000

# Supabase (required)
# Use the Supabase Project URL and the *publishable/anon* key (safe for browser, works with RLS).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Authentication
VITE_AUTH_STORAGE_KEY=cukaipro_auth_token

# Error Monitoring (Sentry) - only enables when set; get DSN from sentry.io
VITE_SENTRY_DSN=

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true

# Testing: unlock pro/enterprise for these emails (comma-separated). Remove when locking paid features.
# Example: VITE_UNLOCK_SUBSCRIPTION_EMAIL=vvssubra87@gmail.com
# VITE_UNLOCK_SUBSCRIPTION_EMAIL=

# Environment
VITE_APP_ENV=development

# MyInvois / LHDN e-Invoicing (server-side only)
# Per-org credentials are entered by users in Settings → E-Invoicing and stored encrypted.
# Set CREDENTIALS_ENCRYPTION_KEY as a Supabase Edge Function secret (hex-encoded 256-bit key).
# Generate with: openssl rand -hex 32
# CREDENTIALS_ENCRYPTION_KEY=
# Optional: frontend can know base URL for status links (no secrets)
# VITE_MYINVOIS_PORTAL_URL=https://myinvois.hasil.gov.my
