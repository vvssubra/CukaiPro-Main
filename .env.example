# API Configuration
VITE_API_BASE_URL=https://api.cukaipro.com/v1
VITE_API_TIMEOUT=30000

# Supabase (required)
# Use the Supabase Project URL and the *publishable/anon* key (safe for browser, works with RLS).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Authentication
VITE_AUTH_STORAGE_KEY=cukaipro_auth_token

# Error Monitoring (Sentry) - only enables when set; get DSN from sentry.io
VITE_SENTRY_DSN=

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true

# Environment
VITE_APP_ENV=development

# MyInvois / LHDN e-Invoicing (server-side only: client_id and client_secret must NOT be in frontend)
# Configure these in Supabase Edge Function secrets or your backend; never expose in client.
# MYINVOIS_IDENTITY_URL=https://identity.myinvois.hasil.gov.my
# MYINVOIS_API_URL=https://api.myinvois.hasil.gov.my
# MYINVOIS_CLIENT_ID=
# MYINVOIS_CLIENT_SECRET=
# MYINVOIS_SANDBOX=true
# Optional: frontend can know base URL for status links (no secrets)
# VITE_MYINVOIS_PORTAL_URL=https://myinvois.hasil.gov.my
