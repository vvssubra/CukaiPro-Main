# API Configuration
VITE_API_BASE_URL=https://api.cukaipro.com/v1
VITE_API_TIMEOUT=30000

# Supabase (required)
# Use the Supabase Project URL and the *publishable/anon* key (safe for browser, works with RLS).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Authentication
VITE_AUTH_STORAGE_KEY=cukaipro_auth_token

# Error Monitoring (Sentry) - only enables when set; get DSN from sentry.io
VITE_SENTRY_DSN=

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true

# Environment
VITE_APP_ENV=development
